        "prlimit64", "getrlimit", "setrlimit",
        "uname", "sysinfo",
        "pread64", "pwrite64", "readv", "writev",
        "sendfile", "splice", "tee"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
