# VigilClaw 环境变量示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ============================================================
# 必填 — 核心安全
# ============================================================

# 64 位十六进制主密钥（openssl rand -hex 32 生成）
# 不填则自动生成并保存到 ~/.config/vigilclaw/master.key
VIGILCLAW_MASTER_KEY=

# ============================================================
# 必填 — 至少配置一个消息渠道
# ============================================================

# Telegram（通过 @BotFather 获取）
VIGILCLAW_TELEGRAM_BOT_TOKEN=

# 飞书（企业自建应用）
# VIGILCLAW_FEISHU_APP_ID=
# VIGILCLAW_FEISHU_APP_SECRET=
# VIGILCLAW_FEISHU_ENCRYPT_KEY=
# VIGILCLAW_FEISHU_VERIFY_TOKEN=

# 钉钉（企业内部应用）
# VIGILCLAW_DINGTALK_APP_KEY=
# VIGILCLAW_DINGTALK_APP_SECRET=
# VIGILCLAW_DINGTALK_ROBOT_CODE=

# ============================================================
# 必填 — 至少配置一个 LLM Provider
# ============================================================

# Anthropic Claude（https://console.anthropic.com）
ANTHROPIC_API_KEY=

# 可选：自定义 API 中转地址（兼容 Anthropic 协议的代理）
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/anthropic
# ANTHROPIC_AUTH_TOKEN=

# 使用的模型，默认 claude-sonnet-4-5-20250929
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5-20251001

# OpenAI（https://platform.openai.com）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Ollama（本地模型，需先启动 ollama serve）
# VIGILCLAW_OLLAMA_BASE_URL=http://localhost:11434
# VIGILCLAW_OLLAMA_MODEL=llama3.1

# 默认 Provider：claude | openai | ollama
# VIGILCLAW_DEFAULT_PROVIDER=claude

# ============================================================
# 容器运行时
# ============================================================

# auto | docker | apple | local
# auto：自动检测；local：无容器本地模式（开发/调试用）
VIGILCLAW_CONTAINER_RUNTIME=auto

# 无 Docker/Apple Container 时设为 true（等同于 runtime=local）
# VIGILCLAW_LOCAL_MODE=false

# Docker 镜像（使用默认值通常无需修改）
# VIGILCLAW_DOCKER_IMAGE=vigilclaw/agent-runner:latest

# ============================================================
# 可选 — 数据存储
# ============================================================

# VIGILCLAW_DB_PATH=./data/vigilclaw.db
# VIGILCLAW_DATA_DIR=./data

# ============================================================
# 可选 — 知识图谱记忆（结构化实体-关系记忆）
# ============================================================

# 是否启用知识图谱记忆（默认 true；纯 SQLite，零外部依赖）
# VIGILCLAW_KG_ENABLED=true
# 图谱遍历跳数（1-3，默认 1）
# VIGILCLAW_KG_MAX_HOPS=1
# 单次召回最多注入的关系事实数（默认 10）
# VIGILCLAW_KG_MAX_FACTS=10

# ============================================================
# 可选 — Skill：Web Search
# ============================================================

# Brave Search API Key（https://api.search.brave.com）
# BRAVE_SEARCH_API_KEY=

# ============================================================
# 可选 — 日志与调试
# ============================================================

# debug | info | warn | error
# VIGILCLAW_LOG_LEVEL=info

# API 请求超时（毫秒）
# API_TIMEOUT_MS=300000
